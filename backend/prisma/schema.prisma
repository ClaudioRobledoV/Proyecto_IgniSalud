// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS de la aplicación
enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

// MODELOS
model User {
  id        String   @id @default(uuid())
  rut       String   @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
}

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  address   String?
  age       Int?
  allergies String?  // Relacionado con RF03
  
  // Relaciones
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
}

model DoctorProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  specialty String?
  
  // Relaciones relacionadas con RF04
  appointments   Appointment[]
  medicalRecords MedicalRecord[] 
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  date        DateTime // Fecha y Hora (RF07)
  status      AppointmentStatus @default(PENDING) // RF08
  createdAt   DateTime @default(now())
  
  // Relaciones
  patient        PatientProfile @relation(fields: [patientId], references: [id])
  doctor         DoctorProfile  @relation(fields: [doctorId], references: [id])
  medicalRecord  MedicalRecord? 
}

model MedicalRecord {
  id            String   @id @default(uuid())
  patientId     String
  doctorId      String
  appointmentId String?  @unique
  
  symptoms      String?  // RF10 (Recolectado por Chatbot)
  diagnosis     String?
  notes         String?  // RF12 (Voz a texto del Médico)
  priority      PriorityLevel? // RF11 (Triage)
  
  createdAt     DateTime @default(now())

  // Relaciones
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  doctor        DoctorProfile  @relation(fields: [doctorId], references: [id])
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
}
